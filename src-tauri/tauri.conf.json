{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "photo-selector",
  "version": "1.0.1",
  "identifier": "com.pixelengineering.photo-selector",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Photo Selector",
        "width": 1280,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Photography",
    "shortDescription": "Fast photo selection and culling tool",
    "longDescription": "Select and reject photos quickly. Organises images into selected and rejected folders."
  }
  
}
